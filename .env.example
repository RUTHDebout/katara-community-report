# KATARA Community Report environment variables

# App
APP_NAME=katara-community-report
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/katara

# Storage
STORAGE_PROVIDER=local
STORAGE_BUCKET=katara-uploads

# Maps
MAP_PROVIDER=leaflet
MAPBOX_TOKEN=

# SMS / WhatsApp
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# RAG / AI
OPENAI_API_KEY=
VECTOR_DB_PROVIDER=chroma
VECTOR_DB_URL=http://localhost:8001

# Google Earth Engine
GEE_SERVICE_ACCOUNT=
GEE_PRIVATE_KEY_PATH=

# Security
JWT_SECRET=change-me
ADMIN_EMAIL=
